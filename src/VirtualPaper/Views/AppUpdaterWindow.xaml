<ui:FluentWindow x:Class="VirtualPaper.Views.AppUpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VirtualPaper.Views"
        xmlns:vms="clr-namespace:VirtualPaper.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:lang="clr-namespace:VirtualPaper.lang"
        xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
        ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStyle="None"
        Height="600" Width="800"
        ResizeMode="CanMinimize"
        Title="Virtual Paper Updater"
        ExtendsContentIntoTitleBar="True"
        Closing="FluentWindow_Closing"
        Closed="FluentWindow_Closed"
        PreviewKeyDown="FluentWindow_PreviewKeyDown">

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Title="Virtual Paper Updater"
            CloseWindowByDoubleClickOnIcon="True"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            ShowMaximize="False"
            Height="48">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{Binding AppIconPath}" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 主体：更新日志 -->
        <ScrollViewer x:Name="scroller"
            Grid.Row="1"
            Padding="24,16"
            VerticalScrollBarVisibility="Auto"
            Background="{DynamicResource SolidBackgroundFillColorSecondary}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                    <TextBlock Text="✨"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0"
                               Foreground="Orange"/>
                    <TextBlock Text="Virtual Paper"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding Version}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <mdxam:MarkdownScrollViewer x:Name="Changelog"
                    VerticalScrollBarVisibility="Disabled"
                    PreviewMouseWheel="MarkdownScrollViewer_PreviewMouseWheel"
                    Background="Transparent"
                    Markdown="{Binding ChangeLog}">
                    <mdxam:MarkdownScrollViewer.MarkdownStyle>
                        <Style BasedOn="{x:Static mdxam:MarkdownStyle.GithubLike}" TargetType="FlowDocument" />
                    </mdxam:MarkdownScrollViewer.MarkdownStyle>
                </mdxam:MarkdownScrollViewer>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Margin="0 0 0 10"
                Padding="20,12"
                Width="600"
                CornerRadius="10"
                BorderThickness="1,0,0,1"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：进度与状态 -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="13"/>

                    <ProgressBar Height="8"
                                 Margin="0,8,0,0"                                 
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                 Background="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                 Value="{Binding Progress}"
                                 Minimum="0" Maximum="100"/>

                    <TextBlock Text="{Binding SpeedText}"
                               FontSize="12"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- 右侧：操作按钮 -->
                <ui:Button Grid.Column="1"
                           Content="{Binding ActionButtonText}"
                           Command="{Binding ActionCommand}"
                           IsEnabled="{Binding ActionButtonEnable}"
                           Appearance="Primary"
                           Width="100"
                           Height="36"
                           Margin="8,0"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <ContentPresenter x:Name="RootContentDialog" Grid.RowSpan="3"/>
    </Grid>
</ui:FluentWindow>
