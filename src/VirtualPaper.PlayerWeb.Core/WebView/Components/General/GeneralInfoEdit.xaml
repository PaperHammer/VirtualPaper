<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.PlayerWeb.Core.WebView.Components.General.GeneralInfoEdit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.PlayerWeb.Core.WebView.Components.General"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid"
        HorizontalAlignment="Stretch"
        Padding="3 8 0 8">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Padding="10 8 16 0">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Vertical" Spacing="5">
                    <TextBlock x:Name="titleText" 
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{markup:I18n Key=Text_Edit_Title}"/>
                    <TextBox x:Name="titleValue" 
                        Text="{x:Bind _viewModel.Title, Mode=TwoWay}"
                        TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="5">
                    <TextBlock x:Name="descText" 
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{markup:I18n Key=Text_Edit_Desc}"/>
                    <TextBox x:Name="descValue" 
                        Text="{x:Bind _viewModel.Desc, Mode=TwoWay}"
                        TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="5">
                    <TextBlock x:Name="tagsText" 
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{markup:I18n Key=Text_Edit_Tags}"/>
                    <TextBox x:Name="tagInput" 
                        KeyDown="TagInput_KeyDown"
                        TextWrapping="Wrap"/>
                    <ItemsRepeater HorizontalAlignment="Stretch" ItemsSource="{x:Bind _viewModel.TagList}">
                        <ItemsRepeater.Layout>
                            <LinedFlowLayout LineSpacing="6" MinItemSpacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <ItemContainer>
                                    <Grid
                                        CornerRadius="5"
                                        Background="{StaticResource AccentFillColorSelectedTextBackgroundBrush}"                                               
                                        Padding="8 5"
                                        HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock 
                                            Text="{x:Bind}"
                                            Margin="0 0 0 1"
                                            Foreground="White"
                                            VerticalAlignment="Center"/>
                                        <input:ArcButton
                                            Grid.Column="2"
                                            Tag="{x:Bind}"
                                            Padding="4"
                                            Background="Transparent"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="TagDelButton_Click">
                                            <FontIcon 
                                                FontFamily="Segoe MDL2 Assets"
                                                Glyph="&#xE711;"
                                                FontSize="14"/>
                                        </input:ArcButton>
                                    </Grid>
                                </ItemContainer>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel 
            Grid.Row="1" 
            HorizontalAlignment="Right" 
            Orientation="Horizontal"
            Padding="0 0 16 0">
            <Button
                Height="33"
                Margin="10 0 0 0"
                HorizontalAlignment="Right"
                Content="{markup:I18n Key=Text_Save}"
                Command="{x:Bind _viewModel.SaveCommand}"/>
        </StackPanel>
    </Grid>
</Page>
