<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.HSBEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 色相 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="色相" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="HueValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="HueSlider"
            Minimum="0" Maximum="360" Value="0"
            TickFrequency="60" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="HueSlider_ValueChanged"/>

        <!-- 饱和度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="饱和度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="SaturationValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="SaturationSlider"
            Minimum="0" Maximum="400" Value="100"
            TickFrequency="50" TickPlacement="BottomRight"
            SmallChange="4" StepFrequency="4"
            ValueChanged="SaturationSlider_ValueChanged"/>

        <!-- 明度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="明度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="BrightnessValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="BrightnessSlider"
            Minimum="-100" Maximum="100" Value="0"
            TickFrequency="25" TickPlacement="BottomRight"
            SmallChange="2" StepFrequency="2"
            ValueChanged="BrightnessSlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
