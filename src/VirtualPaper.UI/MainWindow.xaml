<Window
    x:Class="VirtualPaper.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winex="using:WinUIEx"
    xmlns:feedback="using:VirtualPaper.UIComponent.Feedback"
    xmlns:models="using:VirtualPaper.UIComponent.Models"
    xmlns:navi="using:VirtualPaper.UIComponent.Navigation"
    mc:Ignorable="d"      
    Closed="WindowEx_Closed"
    Activated="WindowEx_Activated"
    Title="MainWindow">

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="titleBar"
            Title="Virtual Paper"
            IsBackButtonVisible="True"
            BackRequested="TitleBar_BackRequested">
            <!--  This is a workaround for https://github.com/microsoft/microsoft-ui-xaml/issues/10374, once fixed we should just be using IconSource  -->
            <TitleBar.LeftHeader>
                <ImageIcon
                    Height="16"
                    Margin="8,0,0,0"
                    Source="/Assets/Tiles/GalleryIcon.ico" />
            </TitleBar.LeftHeader>
        </TitleBar>

        <!--<Grid x:Name="AppTitleBar"
            Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0" />
                <ColumnDefinition x:Name="IconColumn" Width="Auto" />
                <ColumnDefinition x:Name="TitleColumn" Width="Auto" />
                <ColumnDefinition x:Name="LeftDragColumn" Width="*" />
                <ColumnDefinition x:Name="RightDragColumn" Width="*" />
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Image x:Name="TitleBarIcon"
                Grid.Column="1"
                Width="16"
                Height="16"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Source="ms-appx:///Assets/icon-vp-48.png" />
            <TextBlock x:Name="TitleTextBlock"
                Grid.Column="2"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Virtual Paper" />
        </Grid>-->

        <navi:ArcNavigationView x:Name="NavigationViewControl"
            Grid.Row="1"
            Canvas.ZIndex="0"
            DisplayModeChanged="OnPaneDisplayModeChanged"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"                                
            IsTabStop="False"
            SelectionChanged="OnNavigationViewSelectionChanged">
            <navi:ArcNavigationView.MenuItems>
                <!--<NavigationViewItem 
                    Content="{Binding SidebarGallery}"
                    x:Name="Gallery"
                    Icon="Library"
                    IsSelected="True">
                </NavigationViewItem>-->
                <NavigationViewItem x:Name="Nav_WpSettings">
                    <NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="-10,4,0,4">
                                <FontIcon Glyph="&#xE7B8;" FontSize="25" HorizontalAlignment="Center"/>
                                <TextBlock Text="Repo" FontSize="12" HorizontalAlignment="Center" Margin="0 4 0 0"/>
                            </StackPanel>
                        </DataTemplate>
                    </NavigationViewItem.ContentTemplate>
                </NavigationViewItem>
                <NavigationViewItem x:Name="Nav_Draft"
                    IsSelected="True" >
                    <!--TODO：IsSelected = true 时，若直接设置 Content 为 非IconElement or 非String 时会报错 -->
                    <NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="-10,4,0,4">
                                <FontIcon Glyph="&#xF156;" FontSize="25" HorizontalAlignment="Center"/>
                                <TextBlock Text="Project" FontSize="12" HorizontalAlignment="Center" Margin="0 4 0 0"/>
                            </StackPanel>
                        </DataTemplate>
                    </NavigationViewItem.ContentTemplate>
                </NavigationViewItem>
            </navi:ArcNavigationView.MenuItems>

            <navi:ArcNavigationView.PaneFooter>
                <StackPanel x:Name="FooterStackPanel" 
                            Orientation="Vertical"
                            HorizontalAlignment="Stretch"
                            Margin="-2 0 0 0">
                    <!--<Button x:Name="LightAndDarkButton" 
                            Style="{StaticResource ArcNavigationBackButtonNormalStyle}"
                            VerticalAlignment="Center" 
                            HorizontalContentAlignment="Center"
                            Width="Auto"
                            HorizontalAlignment="Stretch"
                            Tag="{x:Bind _viewModel.Theme, Mode=OneWay}"
                            Command="{x:Bind _viewModel.LightAndDarkSwitchCommand}">-->
                        <Button x:Name="LightAndDarkButton" 
                            Style="{StaticResource ArcNavigationBackButtonNormalStyle}"
                            VerticalAlignment="Center" 
                            HorizontalContentAlignment="Center"
                            Width="Auto"
                            HorizontalAlignment="Stretch"
                            Tag="{x:Bind _viewModel.Theme, Mode=OneWay}"
                            Click="LightAndDarkButton_Click">
                        <ImageIcon
                            Height="25"
                            Width="25"
                            Source="{x:Bind _viewModel.CurrentThemeIcon, Mode=OneWay}"/>
                    </Button>
                </StackPanel>
            </navi:ArcNavigationView.PaneFooter>

            <navi:ArcNavigationView.FooterMenuItems>
                <!--<NavigationViewItem 
                    Content="{Binding SidebarAccount}" 
                    x:Name="Nav_Account" 
                    Icon="Contact" />-->
                <NavigationViewItem x:Name="Nav_AppSettings">
                    <NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="-10,4,0,4">
                                <FontIcon Glyph="&#xE713;" FontSize="25" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </NavigationViewItem.ContentTemplate>
                </NavigationViewItem>
            </navi:ArcNavigationView.FooterMenuItems>

            <!--TODO:
                1. Draft 页导航缓存
                2. Loading 页下放，独立 or 全局-->

            <Grid>
                <Frame
                    x:Name="rootFrame"
                    IsEnabled="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.ControlIsEnable, Mode=OneWay}"/>
                <!--<Frame x:Name="ContentFrame"
                    Opacity="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.ControlOpacity, Mode=OneWay}"
                    Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                    IsEnabled="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.ControlIsEnable, Mode=OneWay}"/>-->

                <ItemsControl 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ItemsSource="{x:Bind _viewModel._basicComponentUtil._globalMsgViewModel.InfobarMessages, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:GlobalMsgInfo">
                            <InfoBar
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                IsIconVisible="True"
                                IsOpen="{x:Bind IsOpen, Mode=TwoWay}"
                                Severity="{x:Bind Severity}"
                                Message="{x:Bind Message}"
                                MaxWidth="900"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <feedback:Loading
                    CancelEnable="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.CancelEnable, Mode=OneWay}"
                    ProgressbarEnable="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.ProgressbarEnable, Mode=OneWay}"
                    CtsTokens="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.CtsTokens, Mode=OneWay}"
                    TotalValue="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.TotalValue, Mode=OneWay}"
                    CurValue="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.CurValue, Mode=OneWay}"
                    TextLoading="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.TextLoading, Mode=OneWay}"
                    TextCancel="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.TextCancel, Mode=OneWay}"
                    Visibility="{x:Bind _viewModel._basicComponentUtil._loadingViewModel.IsVisiable, Mode=OneWay}"/>
            </Grid>
        </navi:ArcNavigationView>
    </Grid>
</Window>
