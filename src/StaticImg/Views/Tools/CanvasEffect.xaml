<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Workloads.Creation.StaticImg.Views.Tools.CanvasEffect"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    xmlns:lcl_models="using:Workloads.Creation.StaticImg.Models"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--  分组标题 ToggleButton 样式  -->
        <Style x:Key="AccordionHeaderStyle" TargetType="ToggleButton">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter
                                    Grid.Column="0"
                                    Content="{TemplateBinding Content}"
                                    VerticalAlignment="Center"/>
                                <FontIcon
                                    x:Name="ChevronIcon"
                                    Grid.Column="1"
                                    FontSize="12"
                                    Glyph="&#xE76C;"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  效果缩略图 DataTemplate  -->
        <DataTemplate x:Key="EffectItemTemplate" x:DataType="lcl_models:CanvasEffectItem">
            <GridViewItem Width="92" Height="108" Margin="3">
                <StackPanel Orientation="Vertical" Spacing="4">
                    <Border
                        Width="90"
                        Height="66"
                        CornerRadius="6">
                        <Image
                            Stretch="UniformToFill"
                            Source="{x:Bind PreviewImagePath, Converter={StaticResource ResourceKeyToImageConverter}}"/>
                    </Border>
                    <TextBlock
                        Width="82"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        FontSize="11"
                        MaxLines="2"
                        TextWrapping="Wrap"
                        Text="{x:Bind EffectName}"/>
                </StackPanel>
            </GridViewItem>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="EffectItemsPanel">
            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3"/>
        </ItemsPanelTemplate>

    </UserControl.Resources>

    <Expander Style="{StaticResource RightExpanderStyle}">
        <Expander.Header>
            <TextBlock Text="{markup:I18n Key=Project_StaticImg_ToolName_CanvasEffect}"/>
        </Expander.Header>
        <Expander.Content>
            <StackPanel Orientation="Vertical" Spacing="6">

                <!-- ══ 分组 1：调整 ══ -->
                <ToggleButton
                    x:Name="Header_Adjust"
                    Style="{StaticResource AccordionHeaderStyle}"
                    Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Adjust}"
                    Checked="GroupHeader_Checked"
                    Unchecked="GroupHeader_Unchecked"/>
                <Grid x:Name="Content_Adjust" MaxHeight="0">
                    <GridView
                        x:Name="EffectGrid_Adjust"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemTemplate="{StaticResource EffectItemTemplate}"
                        ItemsPanel="{StaticResource EffectItemsPanel}"
                        ItemClick="EffectGridView_ItemClick"/>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- ══ 分组 2：颜色 ══ -->
                <ToggleButton
                    x:Name="Header_Color"
                    Style="{StaticResource AccordionHeaderStyle}"
                    Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Color}"
                    Checked="GroupHeader_Checked"
                    Unchecked="GroupHeader_Unchecked"/>
                <Grid x:Name="Content_Color" MaxHeight="0">
                    <GridView
                        x:Name="EffectGrid_Color"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemTemplate="{StaticResource EffectItemTemplate}"
                        ItemsPanel="{StaticResource EffectItemsPanel}"
                        ItemClick="EffectGridView_ItemClick"/>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- ══ 分组 3：艺术 ══ -->
                <ToggleButton
                    x:Name="Header_Artistic"
                    Style="{StaticResource AccordionHeaderStyle}"
                    Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Artistic}"
                    Checked="GroupHeader_Checked"
                    Unchecked="GroupHeader_Unchecked"/>
                <Grid x:Name="Content_Artistic" MaxHeight="0">
                    <GridView
                        x:Name="EffectGrid_Artistic"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemTemplate="{StaticResource EffectItemTemplate}"
                        ItemsPanel="{StaticResource EffectItemsPanel}"
                        ItemClick="EffectGridView_ItemClick"/>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- ══ 分组 4：特效 ══ -->
                <ToggleButton
                    x:Name="Header_Special"
                    Style="{StaticResource AccordionHeaderStyle}"
                    Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Special}"
                    Checked="GroupHeader_Checked"
                    Unchecked="GroupHeader_Unchecked"/>
                <Grid x:Name="Content_Special" MaxHeight="0">
                    <GridView
                        x:Name="EffectGrid_Special"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemTemplate="{StaticResource EffectItemTemplate}"
                        ItemsPanel="{StaticResource EffectItemsPanel}"
                        ItemClick="EffectGridView_ItemClick"/>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- ══ 分组 5：混合 ══ -->
                <ToggleButton
                    x:Name="Header_Blend"
                    Style="{StaticResource AccordionHeaderStyle}"
                    Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Blend}"
                    Checked="GroupHeader_Checked"
                    Unchecked="GroupHeader_Unchecked"/>
                <Grid x:Name="Content_Blend" MaxHeight="0">
                    <GridView
                        x:Name="EffectGrid_Blend"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemTemplate="{StaticResource EffectItemTemplate}"
                        ItemsPanel="{StaticResource EffectItemsPanel}"
                        ItemClick="EffectGridView_ItemClick"/>
                </Grid>

                <!--  底部操作按钮  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Button
                        Content="{markup:I18n Key=Text_Cancel}"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        Click="SelectCancelBtn_Click"/>

                    <Button
                        Grid.Column="2"
                        Content="{markup:I18n Key=Text_Complete}"
                        Height="40"
                        HorizontalAlignment="Stretch"
                        Click="SelectCommitBtn_Click"/>
                </Grid>

            </StackPanel>
        </Expander.Content>
    </Expander>
</UserControl>
