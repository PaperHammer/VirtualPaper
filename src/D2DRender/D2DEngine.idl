//import "Windows.Foundation.Numerics.idl";

namespace D2DEngine
{
    enum RotateDirection {
        Left = 0,
        Right = 1
    };

    enum LayerType  
    {
        Bitmap = 0,
        Vector = 1
    };

    enum StrokeTool
    {
        Brush = 0,
        Eraser = 1
    };

    struct FillOptions
    {
        Windows.Foundation.Numerics.Vector4 Color;
        Single Opacity;    // 0~1
        Single Tolerance;  // 0~1
    };

    struct StrokeOptions
    {
        StrokeTool Tool;
        Windows.Foundation.Numerics.Vector4 Color; // RGBA
        Single Thickness;
        Single Opacity; // 0~1
    };

    enum AreaHandle
    {
        None = 0,
        TopLeft, TopCenter, TopRight,
        MiddleLeft, MiddleRight,
        BottomLeft, BottomCenter, BottomRight,
        Move
    };

    struct Area
    {
        Windows.Foundation.Rect Rect;
        Windows.Foundation.Rect OriginalRect;
        Boolean Active;
        Single HandleSize;
        Boolean IsOverlay;
        Single OverlayOpacity;
    };

    [default_interface]
    runtimeclass Layer
    {
        Layer(String name, Int32 width, Int32 height, LayerType type);

        String Name { get; set; };
        Int32 Width { get; };
        Int32 Height { get; };
        LayerType Type { get; };
        Boolean Visible { get; set; };
        Double Opacity { get; set; };

        void Resize(Int32 newWidth, Int32 newHeight, Boolean scaleContent);
        void Rotate(RotateDirection direction);
        void FlipHorizontal();
        void FlipVertical();
    }

    [default_interface]
    runtimeclass LayerManager
    {
        LayerManager();

        Layer GetLayer(Int32 index);
        Int32 LayerCount { get; };

        void AddLayer(Layer layer);
        void RemoveLayer(Int32 index);
        void MoveLayer(Int32 fromIndex, Int32 toIndex);       
        void Clear();
    }
}
