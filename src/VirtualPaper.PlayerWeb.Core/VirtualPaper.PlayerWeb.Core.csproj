		  <Generator>MSBuild:Compile</Generator>
		</Page>
		<Page Update="WebView\Components\DataConfig.xaml">
		  <Generator>MSBuild:Compile</Generator>
		</Page>
	</ItemGroup>
	<ItemGroup>
		<Page Update="WebView\Components\SlidingSidePanel.xaml">
			<SubType>Designer</SubType>
		</Page>
		<Page Update="WebView\Page\MainPage.xaml">
			<SubType>Designer</SubType>
		</Page>
		<Page Update="WebView\Window\PreviewWithWeb.xaml">
			<SubType>Designer</SubType>
		</Page>
	</ItemGroup>

</Project>