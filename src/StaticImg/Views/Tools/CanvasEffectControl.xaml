<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Workloads.Creation.StaticImg.Views.Tools.CanvasEffectControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    xmlns:lcl_models="using:Workloads.Creation.StaticImg.Models"
    xmlns:collection="using:VirtualPaper.UIComponent.Collection"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--  分组标题 ToggleButton 样式  -->
        <Style x:Key="AccordionHeaderStyle" TargetType="ToggleButton">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ChevronIcon"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ContentText"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource AccentFillColorSecondaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ChevronIcon"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ContentText"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource AccentFillColorTertiaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ChevronIcon"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ContentText"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                    Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="ContentText"
                                    Grid.Column="0"
                                    Text="{TemplateBinding Content}"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"/>
                                <FontIcon
                                    x:Name="ChevronIcon"
                                    Grid.Column="1"
                                    FontSize="10"
                                    Glyph="&#xE76C;"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  效果列表 DataTemplate（名称 + 描述）  -->
        <DataTemplate x:Key="EffectItemTemplate" x:DataType="lcl_models:CanvasEffectItem">
            <StackPanel Orientation="Vertical" Spacing="2" Padding="8,6">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Text="{x:Bind EffectName}"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock
                    FontSize="11"
                    MaxLines="2"
                    TextWrapping="Wrap"
                    TextTrimming="CharacterEllipsis"
                    Text="{x:Bind EffectDescription}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="EffectItemsPanel">
            <ItemsStackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

    </UserControl.Resources>

    <Expander Style="{StaticResource RightExpanderStyle}">
        <Expander.Header>
            <TextBlock Text="{markup:I18n Key=Project_StaticImg_ToolName_CanvasEffect}"/>
        </Expander.Header>
        <Expander.Content>
            <StackPanel Orientation="Vertical" Spacing="8">

                <!--  顶部操作区  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Button
                        Content="{markup:I18n Key=Text_Cancel}"
                        Height="36"
                        HorizontalAlignment="Stretch"
                        Click="SelectCancelBtn_Click"/>

                    <Button
                        Grid.Column="2"
                        Content="{markup:I18n Key=Text_Complete}"
                        Height="36"
                        HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="SelectCommitBtn_Click"/>
                </Grid>

                <!--  分隔线  -->
                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <!-- 分组 1：调整 -->
                <StackPanel Spacing="2">
                    <ToggleButton
                        x:Name="Header_Adjust"
                        Style="{StaticResource AccordionHeaderStyle}"
                        Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Adjust}"
                        Checked="GroupHeader_Checked"
                        Unchecked="GroupHeader_Unchecked"/>
                    <Grid x:Name="Content_Adjust" MaxHeight="0">
                        <collection:ArcListView
                            x:Name="EffectGrid_Adjust"
                            SelectionMode="Single"
                            CancelSelectionEnable="False"
                            IsAllwaysSeletedNewItem="False"
                            IsItemClickEnabled="True"
                            Padding="0,0,16,0"
                            ItemTemplate="{StaticResource EffectItemTemplate}"
                            ItemsPanel="{StaticResource EffectItemsPanel}"
                            ItemClick="EffectGridView_ItemClick"/>
                    </Grid>
                </StackPanel>

                <!-- 分组 3：特效 -->
                <StackPanel Spacing="2">
                    <ToggleButton
                        x:Name="Header_Special"
                        Style="{StaticResource AccordionHeaderStyle}"
                        Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Special}"
                        Checked="GroupHeader_Checked"
                        Unchecked="GroupHeader_Unchecked"/>
                    <Grid x:Name="Content_Special" MaxHeight="0">
                        <collection:ArcListView
                            x:Name="EffectGrid_Special"
                            SelectionMode="Single"
                            CancelSelectionEnable="False"
                            IsAllwaysSeletedNewItem="False"
                            IsItemClickEnabled="True"
                            Padding="0,0,16,0"
                            ItemTemplate="{StaticResource EffectItemTemplate}"
                            ItemsPanel="{StaticResource EffectItemsPanel}"
                            ItemClick="EffectGridView_ItemClick"/>
                    </Grid>
                </StackPanel>

                <!-- 分组 4：混合 -->
                <StackPanel Spacing="2">
                    <ToggleButton
                        x:Name="Header_Blend"
                        Style="{StaticResource AccordionHeaderStyle}"
                        Content="{markup:I18n Key=Project_StaticImg_EffectGroup_Blend}"
                        Checked="GroupHeader_Checked"
                        Unchecked="GroupHeader_Unchecked"/>
                    <Grid x:Name="Content_Blend" MaxHeight="0">
                        <collection:ArcListView
                            x:Name="EffectGrid_Blend"
                            SelectionMode="Single"
                            CancelSelectionEnable="False"
                            IsAllwaysSeletedNewItem="False"
                            IsItemClickEnabled="True"
                            Padding="0,0,16,0"
                            ItemTemplate="{StaticResource EffectItemTemplate}"
                            ItemsPanel="{StaticResource EffectItemsPanel}"
                            ItemClick="EffectGridView_ItemClick"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </Expander.Content>
    </Expander>
</UserControl>
