<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.UIComponent.Others.RenameView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.UIComponent.Others"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:cvs="using:VirtualPaper.UIComponent.Converters"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d">

    <UserControl.Resources>
        <cvs:VisibilityByValueConverter x:Key="VisibilityByValueConverter"/>
    </UserControl.Resources>

    <StackPanel
        Orientation="Vertical"
        Spacing="8">
        <StackPanel
            Spacing="4">
            <TextBlock
                Text="{markup:I18n Key=RenameDialog_Text_BeforeChange}"
                FontWeight="Bold"
                FontSize="12"/>
            <TextBlock
                Text="{x:Bind _viewModel.OldName}"
                FontSize="12"/>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Orientation="Vertical"
            HorizontalAlignment="Left"
            Spacing="6">
            <TextBlock
                Text="{markup:I18n Key=RenameDialog_Text_AfterChange}"
                FontWeight="Bold"
                FontSize="12"/>

            <TextBox
                IsSpellCheckEnabled="False"
                Text="{x:Bind _viewModel.NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                FontSize="12"
                Width="500">
            </TextBox>

            <StackPanel
                Orientation="Horizontal"
                Spacing="4"
                Margin="2 0 0 0"
                Visibility="{x:Bind _viewModel.IsNameOk, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=!}">
                <FontIcon 
                    FontSize="14"
                    VerticalAlignment="Bottom"
                    Foreground="Red"
                    Glyph="&#xE783;" />

                <TextBlock
                    Text="{markup:I18n Key=Project_NewName_InvalidTip}"
                    FontSize="12"
                    Foreground="Red"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
