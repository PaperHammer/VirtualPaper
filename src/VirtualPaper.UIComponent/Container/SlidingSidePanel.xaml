<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.UIComponent.Container.SlidingSidePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.UIComponent.Container"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" VerticalAlignment="Top">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="TranslateX" />
        </Grid.RenderTransform>

        <StackPanel Orientation="Horizontal">
            <!-- A 区域 -->
            <Border x:Name="HandleArea"
                Width="30"
                Height="80"
                Background="#444"
                CornerRadius="0,8,8,0"
                VerticalAlignment="Center"
                PointerPressed="Handle_PointerPressed"
                PointerReleased="Handle_PointerReleased"
                PointerMoved="Handle_PointerMoved">
                <TextBlock Text="≡"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="22"
                    Foreground="White"/>
            </Border>

            <!-- 内容区域（可放任意控件） -->
            <Border x:Name="ContentArea"
                    Width="260"
                    Background="#262626"
                    CornerRadius="12,0,0,12"
                    Padding="12"
                    Opacity="0.98">
                <ContentPresenter x:Name="PART_ContentPresenter"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
