<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.DraftPanel.Views.ConfigSpace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.DraftPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="using:VirtualPaper.UIComponent.Data"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <data:Card x:Name="ConfigSpaceCard"
        Width="970" 
        Height="680"
        Padding="50"
        CornerRadius="12"
        Elevation="64"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <Grid x:Name="ConfigSpaceGrid">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Frame x:Name="FrameComp" Loaded="FrameComp_Loaded"/>

            <Grid Grid.Row="1" Visibility="{x:Bind _viewModel.BtnVisible, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6">
                    <input:ArcButton
                        Content="{x:Bind _viewModel.PreviousStepBtnText, Mode=OneWay}"
                        Command="{x:Bind _viewModel.PreviousStepCommand}"
                        Width="100"
                        FontSize="12"/>

                    <input:ArcButton
                        Content="{x:Bind _viewModel.NextStepBtnText, Mode=OneWay}"
                        IsEnabled="{x:Bind _viewModel.IsNextEnable, Mode=OneWay}"
                        Width="100"
                        Command="{x:Bind _viewModel.NextStepCommand}"
                        FontSize="12"
                        Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </data:Card>
</arc:ArcPage>
