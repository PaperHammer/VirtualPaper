<ui:FluentWindow x:Class="VirtualPaper.Views.RestartUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:lang="clr-namespace:VirtualPaper.lang"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
        ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStyle="None"
        Height="300" Width="500"
        ResizeMode="NoResize"
        Title="Virtual Paper Update"
        Icon="pack://application:,,,/Resources/appicon_download.png"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar
            Title="Virtual Paper Update"
            CloseWindowByDoubleClickOnIcon="True"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            ShowMaximize="False"
            ShowMinimize="False"
            Height="40">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/appicon_download.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Content -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Margin="40,20">
            
            <!-- Stage Icon -->
            <ui:SymbolIcon x:Name="StageIcon"
                           Symbol="ArrowDownload32"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>

            <!-- Stage Text -->
            <TextBlock Text="{Binding StageText}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <!-- Detail Text -->
            <TextBlock Text="{Binding DetailText}"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- Progress Bar -->
            <ProgressBar Height="6"
                         Width="400"
                         Value="{Binding Progress}"
                         Minimum="0" Maximum="100"
                         IsIndeterminate="{Binding IsIndeterminate, FallbackValue=False}"
                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                         Background="{DynamicResource ControlStrokeColorSecondaryBrush}"/>

            <!-- Status Text -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>

            <!-- Postpone Tip (shown after completion) -->
            <TextBlock Text="{Binding PostponeTip}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Bottom Bar -->
        <Border Grid.Row="2"
                Padding="20,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <ui:Button 
                       Command="{Binding CloseCommand}"
                       IsEnabled="{Binding IsCompleted}"
                       Appearance="Primary"
                       Width="100"
                       Height="32"
                       HorizontalAlignment="Right">
                <TextBlock Text="{Binding [RestartUpdate_Close], Source={x:Static lang:LanguageManager.Instance}}"/>
            </ui:Button>
        </Border>
    </Grid>
</ui:FluentWindow>
