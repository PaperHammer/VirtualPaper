<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.AppSettingsPanel.Views.GeneralSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.AppSettingsPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <ScrollView>
        <StackPanel Margin="15 0 15 15" Orientation="Vertical">
            <StackPanel x:Name="Version" Orientation="Vertical">
                <TextBlock x:Name="VersionHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_General_Text_Version}"
                    FontWeight="Bold"/>

                <Grid x:Name="VersionContent"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE117;"/>
                    
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{x:Bind _viewModel.AppVersionText}" FontSize="16"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{x:Bind _viewModel.Version_LastCheckDate, Mode=OneWay}"/>
                        <HyperlinkButton
                            Grid.Row="2"
                            Content="{markup:I18n Key=Settings_General_Version_Release_Notes}"
                            Margin="0"
                            Padding="0"
                            NavigateUri="https://github.com/PaperHammer/VirtualPaper/releases"/>
                    </Grid>

                    <Grid Grid.Column="2" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <ProgressRing x:Name="UpdateProgressRing"
                            IsActive="{x:Bind _viewModel.IsUpdateRingActive, Mode=OneWay}"
                            Margin="40 0"
                            Background="Transparent"/>
                        <Button x:Name="VersionCheckUpdate"
                            Grid.Column="1" 
                            Width="200"
                            HorizontalAlignment="Stretch"
                            Content="{markup:I18n Key=Settings_General_Version_UpdateCheck}"
                            IsEnabled="{x:Bind _viewModel.IsUpdateBtnEnable, Mode=OneWay}"
                            Command="{x:Bind _viewModel.CheckUpdateCommand}"
                            Visibility="{x:Bind _viewModel.IsWinStore, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=!}"/>
                    </Grid>
                </Grid>

                <InfoBar x:Name="InfoBarFindNew"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Visibility="{x:Bind _viewModel.CurrentVersionState, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=FindNew}"
                    Title="{markup:I18n Key=Settings_General_Version_FindNew}"
                    Message="{x:Bind _viewModel.Version, Mode=OneWay}" >
                    <InfoBar.Content>
                        <Grid Padding="10 0" Margin="0 0 0 10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Button
                                Content="{markup:I18n Key=Settings_General_Version_DownloadStart}"
                                IsEnabled="{x:Bind _viewModel.IsUpdateBtnEnable, Mode=OneWay}"
                                Width="100"
                                Command="{x:Bind _viewModel.StartDownloadComand}"/>

                            <HyperlinkButton
                                Grid.Column="1"
                                Content="{markup:I18n Key=Settings_General_Version_SeeNews}"
                                HorizontalAlignment="Right"
                                NavigateUri="https://github.com/PaperHammer/VirtualPaper/releases"/>
                        </Grid>
                    </InfoBar.Content>
                </InfoBar>

                <InfoBar x:Name="InfoBarNetErr"
                    Visibility="{x:Bind _viewModel.CurrentVersionState, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=UpdateErr}"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Error"
                    Title="{markup:I18n Key=Settings_General_Version_UpdateErr}"/>

                <InfoBar x:Name="InfoBarUptoNewest"
                    Visibility="{x:Bind _viewModel.CurrentVersionState, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=UptoNewest}"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Success"
                    Title="{markup:I18n Key=Settings_General_Version_UptoNewest}" >
                </InfoBar>
            </StackPanel>

            <StackPanel x:Name="AppearanceAndAction"
                Margin="0 20 0 0"
                Orientation="Vertical">

                <TextBlock x:Name="AppearanceAndActionHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_General_Text_AppearanceAndAction}"
                    FontWeight="Bold"/>

                <Grid x:Name="AutoStart"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE768;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AutoStart}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AutoStatExplain}"/>
                    </Grid>

                    <ToggleButton
                        Grid.Column="2"
                        Width="200"
                        Content="{x:Bind _viewModel.AutoStartStatu, Mode=OneWay}" 
                        IsChecked="{x:Bind _viewModel.IsAutoStart, Mode=TwoWay}"/>
                </Grid>

                <Grid x:Name="SystemBackdrop"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE727;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppSystemBackdrop}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppSystemBackdropExplain}"/>
                        <StackPanel
                            Grid.Row="2"
                            Margin="0"
                            Padding="0"
                            Orientation="Horizontal">
                            <HyperlinkButton 
                                Margin="0"
                                Padding="0"
                                Content="{markup:I18n Key=Settings_General_AppearanceAndAction_AppSystemBackdrop_Mica_Hyperlink}"
                                NavigateUri="https://learn.microsoft.com/en-us/windows/apps/design/style/mica"/>
                            <HyperlinkButton 
                                Margin="15 0 0 0"
                                Padding="0"
                                Content="{markup:I18n Key=Settings_General_AppearanceAndAction_AppSystemBackdrop_Acrylic_Hyperlink}"
                                NavigateUri="https://learn.microsoft.com/en-us/windows/apps/design/style/acrylic"/>
                        </StackPanel>

                    </Grid>

                    <ComboBox x:Name="AppSystemBackdropCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.SystemBackdrops}"
                        SelectedIndex="{x:Bind _viewModel.SeletedSystemBackdropIndx, Mode=TwoWay}"
                        Width="200" />
                </Grid>

                <Grid x:Name="Language"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xF2B7;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppLanguage}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppLanguageExplain}"/>
                    </Grid>

                    <ComboBox x:Name="AppLanguageCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.Languages}"
                        SelectedItem="{x:Bind _viewModel.SelectedLanguage, Mode=TwoWay}"
                        DisplayMemberPath="Language"
                        SelectedValuePath="Language"
                        Width="200" />
                </Grid>

                <Expander x:Name="FileStorage"
                    Margin="0 5"
                    Padding="20 0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Expander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Margin="0 0 20 0" Glyph="&#xE8B7;"/>

                            <Grid Margin="0 23" Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppFileStorage}"/>
                                <TextBlock
                                    Grid.Row="1"                                        
                                    Text="{markup:I18n Key=Settings_General_AppearanceAndAction_AppFileStorageExplain}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </Grid>
                    </Expander.Header>
                    <Expander.Content>
                        <StackPanel Orientation="Vertical" Margin="35 0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="FileStorageButton"
                                    ToolTipService.ToolTip="{markup:I18n Key=Settings_General_AppearanceAndAction_AppFileStorage_ModifyTooltip}"
                                    Content="{x:Bind _viewModel.WallpaperDir, Mode=OneWay}"
                                    IsEnabled="{x:Bind _viewModel.IsWallpaperDirectoryChangeEnable, Mode=OneWay}"
                                    MaxWidth="700"
                                    HorizontalContentAlignment="Left"
                                    Command="{x:Bind _viewModel.ChangeFileStorageCommand}"/>

                                <Button x:Name="OpenFileStorageButton"
                                    Grid.Column="1"
                                    Margin="10 0"
                                    ToolTipService.ToolTip="{markup:I18n Key=Settings_General_AppearanceAndAction_AppFileStorage_OpenTooltip}"
                                    Command="{x:Bind _viewModel.OpenFileStorageCommand}">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE838;" />
                                    </Button.Content>
                                </Button>

                                <ProgressRing
                                    Width="20"
                                    Height="20"
                                    Grid.Column="2"
                                    IsActive="{x:Bind _viewModel.WallpaperDirectoryChangeOngoing, Mode=OneWay}"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
