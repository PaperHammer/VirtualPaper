<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.WpSettingsPanel.Views.ScreenSaver"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.WpSettingsPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    NavigationCacheMode="Enabled">

    <arc:ArcPage.Resources>
        <MenuFlyout x:Key="MF_FilteredListView">
            <MenuFlyoutItem 
                Text="{markup:I18n Key=Text_Delete}"
                Click="RightClickMenuItem_Click"/>
        </MenuFlyout>
    </arc:ArcPage.Resources>

    <ScrollView VerticalAlignment="Stretch">
        <StackPanel x:Name="VirtualPaperScreenSaver"
            Margin="15 0 15 15"           
            Orientation="Vertical">
            <Expander
                Margin="0 5"
                Padding="20 0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Expander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Margin="0 0 20 0" Glyph="&#xF182;"/>

                        <Grid Margin="0 23" Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{markup:I18n Key=ScreenSaver_Server}"/>
                            <TextBlock
                                Grid.Row="1"                                        
                                Text="{markup:I18n Key=ScreenSaver_ServerExplain}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>

                        <ToggleButton
                            Grid.Column="2"
                            Width="200"
                            Content="{x:Bind _viewModel.ScreenSaverStatu, Mode=OneWay}" 
                            IsChecked="{x:Bind _viewModel.IsScreenSaverOn, Mode=TwoWay}"/>
                    </Grid>
                </Expander.Header>
                <Expander.Content>
                    <ContentControl IsEnabled="{x:Bind _viewModel.IsScreenSaverOn, Mode=OneWay}">
                        <StackPanel
                            Margin="35 10"
                            Orientation="Vertical"
                            HorizontalAlignment="Stretch">
                            <NumberBox 
                                Width="200"
                                HorizontalAlignment="Left"
                                Header="{markup:I18n Key=ScreenSaver_WaitingTime}"
                                Value="{x:Bind _viewModel.WaitingTime, Mode=TwoWay}"
                                SpinButtonPlacementMode="Inline"
                                Minimum="1"
                                Maximum="60"
                                SmallChange="1"
                                LargeChange="1" />

                            <CheckBox
                                IsChecked="{x:Bind _viewModel.IsRunningLock, Mode=TwoWay}"
                                Margin="0 15 0 0">
                                <CheckBox.Content>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{markup:I18n Key=ScreenSaver_RunningLock}"/>
                                        <TextBlock
                                            Grid.Row="1"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="{markup:I18n Key=ScreenSaver_RunningLockExplain}"/>
                                    </Grid>
                                </CheckBox.Content>
                            </CheckBox>

                            <Grid x:Name="DynamicEffects"
                                Height="100"
                                Margin="0 15 0 0"
                                VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{markup:I18n Key=ScreenSaver_DynamicEffects}"/>
                                <TextBlock 
                                    Grid.Row="1" 
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{markup:I18n Key=ScreenSaver_DynamicEffectsExplain}"/>
                                <ComboBox x:Name="DynamicEffectsCombo"
                                    Grid.Row="2"
                                    ItemsSource="{x:Bind _viewModel.Effects}"
                                    SelectedIndex="{x:Bind _viewModel.SeletedEffectIndx, Mode=TwoWay}"
                                    Width="200"
                                    Margin="0 5 0 0"/>
                            </Grid>
                        </StackPanel>
                    </ContentControl>
                </Expander.Content>
            </Expander>

            <Grid x:Name="WhiteList"
                Margin="0 5"
                Padding="15 10"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=ScreenSaver_WhiteListTitle}"/>
                        <TextBlock
                            Grid.Row="1"                                    
                            Height="20"
                            Text="{markup:I18n Key=ScreenSaver_WhiteListExplain}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>

                    <Button
                        Grid.Column="1"
                        Width="100"
                        Height="34"
                        Content="{markup:I18n Key=ScreenSaver_Add}"
                        Command="{x:Bind _viewModel.AddToWhiteListCommand}"/>

                    <TextBox x:Name="TargetProName"
                        Margin="10 0"
                        Height="34"
                        Width="240"
                        Grid.Column="2"
                        PlaceholderText="{markup:I18n Key=ScreenSaver_SeekFromList}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        TextChanged="OnFilterChanged"/>
                </Grid>

                <ListView x:Name="FilteredListView"
                    ItemsSource="{x:Bind _viewModel.ProcsFiltered}"
                    Grid.Row="1"
                    Margin="0 10"
                    SelectionMode="Single"
                    ShowsScrollingPlaceholders="True"
                    Height="400"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                    HorizontalAlignment="Stretch">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ContextFlyout="{StaticResource MF_FilteredListView}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <BitmapIcon 
                                    Width="36"
                                    Height="36"
                                    Margin="6"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    UriSource="{Binding IconPath}" 
                                    ShowAsMonochrome="False"/>
                                <TextBlock 
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="{Binding ProcName}"
                                    Style="{ThemeResource BaseTextBlockStyle}"
                                    Margin="12,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </StackPanel>
    </ScrollView>
</arc:ArcPage>
