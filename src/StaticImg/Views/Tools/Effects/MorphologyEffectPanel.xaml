<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.MorphologyEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 模式 -->
        <ComboBox x:Name="ModeCombo"
            Header="模式"
            SelectedIndex="0"
            SelectionChanged="ModeCombo_SelectionChanged">
            <x:String>膨胀</x:String>
            <x:String>腐蚀</x:String>
        </ComboBox>

        <!-- 宽度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="宽度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="WidthValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="WidthSlider"
            Minimum="1" Maximum="20" Value="3"
            TickFrequency="2" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="WidthSlider_ValueChanged"/>

        <!-- 高度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="高度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="HeightValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="HeightSlider"
            Minimum="1" Maximum="20" Value="3"
            TickFrequency="2" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="HeightSlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
