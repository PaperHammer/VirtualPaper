<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.UIComponent.Navigation.ArcNavigationContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.UIComponent.Navigation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:VirtualPaper.UIComponent.Utils"
    mc:Ignorable="d">

    <Grid>
        <Grid x:Name="PART_KeepAliveBuffer" 
            IsHitTestVisible="False"
            Background="Transparent"/>

        <Frame x:Name="PART_ContentFrame" Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"/>

        <ItemsControl x:Name="PART_InfoBarItemsContaner"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            ItemsSource="{x:Bind utils:GlobalMessageUtil.InfobarMessages}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="utils:GlobalMsgInfo">
                    <InfoBar
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        IsIconVisible="True"
                        IsOpen="{x:Bind IsOpen, Mode=TwoWay}"
                        Severity="{x:Bind Severity}"
                        Message="{x:Bind Message}"
                        MaxWidth="900"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
