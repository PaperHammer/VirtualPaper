<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.PlayerWeb.Core.WebView.Components.SlidingSidePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.PlayerWeb.Core.WebView.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="SlidingSidePanel_Loaded"
    SizeChanged="SlidingSidePanel_SizeChanged">

    <Grid x:Name="RootGrid" 
        VerticalAlignment="Top" 
        HorizontalAlignment="Right"
        Opacity="0.95">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="TranslateXY" />
        </Grid.RenderTransform>

        <StackPanel Orientation="Horizontal">
            <!-- 拖动区域 -->
            <Border x:Name="HandleArea"
                Width="30"
                Height="100"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="8 0 0 8"
                VerticalAlignment="Center"
                PointerPressed="Handle_PointerPressed"
                PointerReleased="Handle_PointerReleased"
                PointerMoved="Handle_PointerMoved">
                <TextBlock 
                    Text="≡"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="22"/>
            </Border>

            <!-- 内容区域 -->
            <Border x:Name="ContentArea"
                Width="340"
                Height="520"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="12,0,0,12">
                <ContentPresenter x:Name="PART_ContentPresenter"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
