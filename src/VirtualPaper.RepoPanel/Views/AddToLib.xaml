<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.RepoPanel.Views.AddToLib"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.RepoPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    AllowDrop="True"
    DragLeave="Page_DragLeave"
    DragOver="Page_DragOver"
    Drop="Page_Drop"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Grid x:Name="DropGrid"
            MinWidth="400"
            Background="Transparent">
            
            <Rectangle
                Margin="1"
                Stroke="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                StrokeDashArray="3"
                StrokeDashCap="Flat"
                StrokeDashOffset="1.5"
                StrokeThickness="2" />
            
            <StackPanel x:Name="AddPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Visible">
                <FontIcon
                    FontSize="45"
                    Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                    Glyph="&#xE8C8;" />
                <TextBlock
                    Text="{markup:I18n Key=Add_To_Lib_DragDropFile}"
                    Margin="0,15,0,0"
                    Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>

            <StackPanel x:Name="AddPanelDrop"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <FontIcon
                    FontSize="45"
                    Foreground="{ThemeResource SystemAccentColor}"
                    Glyph="&#xE8C8;" />
                <TextBlock
                    Text="{markup:I18n Key=Add_To_Lib_AddWallpaperDrop}"
                    Margin="0,15,0,0"
                    Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <InfoBar x:Name="RunningAsAdminWarning"
                Margin="5"
                IsClosable="False"
                IsOpen="{x:Bind _viewModel.IsElevated}"
                Message="{markup:I18n Key=RunningAsAdminWarning}"
                Severity="Warning" />
        </Grid>

        <StackPanel Grid.Row="1" Margin="0 6 0 0" Spacing="2">
            <Button
                Background="Transparent"
                BorderThickness="2"
                Padding="20 0"
                Height="90"
                Command="{x:Bind _viewModel.HandleAddFilesCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <Grid x:Name="AddForFile">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE7C3;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Add_To_Lib_SelectFiles}" FontSize="16"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Add_To_Lib_SelectFiles_Explain}"/>
                    </Grid>

                    <FontIcon Margin="20 0 0 0" Grid.Column="2" Glyph="&#xE76C;" />
                </Grid>
            </Button>

            <Button
                Background="Transparent"
                BorderThickness="2"
                Padding="20 0"
                Height="90"
                Command="{x:Bind _viewModel.HandleAddFoldersCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left">
                <Grid x:Name="AddForFolder">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xED43;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Add_To_Lib_SelectFolder}" FontSize="16"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Add_To_Lib_SelectFolderExplain}"/>
                    </Grid>

                    <FontIcon Margin="20 0 0 0" Grid.Column="2" Glyph="&#xE76C;" />
                </Grid>
            </Button>
    </StackPanel>
    </Grid>
</Page>
