<?xml version="1.0" encoding="utf-8"?>
<arc:ArcWindow
    x:Class="VirtualPaper.PlayerWeb.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.PlayerWeb"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:lcl_views="using:VirtualPaper.PlayerWeb.Views"
    mc:Ignorable="d"    
    Closed="WindowEx_Closed" 
    Width="1400" Height="850"
    Title="Virtual Paper Preview">

    <arc:ArcWindowHost x:Name="MainHost">
        <Frame x:Name="ContentFrame" Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
            Loaded="ContentFrame_Loaded"/>
    </arc:ArcWindowHost>
</arc:ArcWindow>
