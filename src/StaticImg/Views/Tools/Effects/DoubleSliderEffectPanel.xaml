<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.DoubleSliderEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel x:Name="Root" Spacing="8">
        <!-- Slider 1 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="Label1Text" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="Value1Text" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="Slider1"
            ValueChanged="Slider1_ValueChanged"/>

        <!-- Slider 2 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="Label2Text" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="Value2Text" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="Slider2"
            ValueChanged="Slider2_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
