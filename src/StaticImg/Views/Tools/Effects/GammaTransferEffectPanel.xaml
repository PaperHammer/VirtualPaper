<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.GammaTransferEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 振幅 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="振幅" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="AmplitudeValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="AmplitudeSlider"
            Minimum="0" Maximum="200" Value="100"
            TickFrequency="25" TickPlacement="BottomRight"
            SmallChange="2" StepFrequency="2"
            ValueChanged="AmplitudeSlider_ValueChanged"/>

        <!-- 指数 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="指数" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="ExponentValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="ExponentSlider"
            Minimum="1" Maximum="500" Value="100"
            TickFrequency="62" TickPlacement="BottomRight"
            SmallChange="5" StepFrequency="5"
            ValueChanged="ExponentSlider_ValueChanged"/>

        <!-- 偏移 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="偏移" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="OffsetValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="OffsetSlider"
            Minimum="-100" Maximum="100" Value="0"
            TickFrequency="25" TickPlacement="BottomRight"
            SmallChange="2" StepFrequency="2"
            ValueChanged="OffsetSlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
