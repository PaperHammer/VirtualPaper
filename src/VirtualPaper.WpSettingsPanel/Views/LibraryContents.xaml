<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.WpSettingsPanel.Views.LibraryContents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.WpSettingsPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VirtualPaper.Models.Cores.Interfaces"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    NavigationCacheMode="Required">

    <arc:ArcPage.Resources>
        <Style x:Key="LibGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <Grid x:Name="RootGrid" Background="Transparent">
                            <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <ContentPresenter 
                                    x:Name="ContentPresenter"
                                    RenderTransformOrigin="0.5 0.5"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}">
                                    <ContentPresenter.RenderTransform>
                                        <CompositeTransform x:Name="ContentPresenterTransform" ScaleX="1" ScaleY="1"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation 
                                                Storyboard.TargetName="ContentPresenterTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.0"
                                                Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation 
                                                Storyboard.TargetName="ContentPresenterTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.0"
                                                Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation 
                                                Storyboard.TargetName="ContentPresenterTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="0.85"
                                                Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="0.4" EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation 
                                                Storyboard.TargetName="ContentPresenterTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0.85"
                                                Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="0.4" EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </arc:ArcPage.Resources>

    <GridView x:Name="wallpapersLibView"
        Margin="5 0 5 10"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        VerticalContentAlignment="Top"
        HorizontalContentAlignment="Left"
        ItemsSource="{x:Bind _viewModel.LibraryWallpapers, Mode=OneWay}"
        Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" 
        AllowDrop="True"
        DragOver="ItemsView_DragOver"
        Drop="ItemsView_Drop"
        SelectionMode="None" 
        IsItemClickEnabled="True"
        ItemContainerStyle="{StaticResource LibGridViewItemStyle}"
        ItemClick="GridView_ItemClick"
        RightTapped="GridView_RightTapped"       
        PreviewKeyDown="ItemsViewer_PreviewKeyDown">
        <GridView.ItemTemplate>
            <DataTemplate x:DataType="models:IWpBasicData">
                <StackPanel
                    Orientation="Vertical"
                    Width="320"
                    MaxWidth="320"
                    Height="230">
                    <Image
                        Source="{x:Bind ThumbnailPath}"
                        Height="200"
                        Width="320"
                        Stretch="Uniform" 
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch"
                        ImageFailed="Image_ImageFailed"/>
                    <TextBlock 
                        Height="25"
                        Text="{x:Bind Title}"
                        MaxLines="2"
                        FontSize="16"
                        TextWrapping="Wrap"
                        HorizontalTextAlignment="Left"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </DataTemplate>
        </GridView.ItemTemplate>
        <GridView.ContextFlyout>
            <MenuFlyout x:Name="ItemsViewMenu"
                        ShowMode="Transient">
                <MenuFlyoutItem
                    x:Name="Details"
                    Text="{markup:I18n Key=Text_Details}"
                    Click="ContextMenu_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="UpdateConfig"
                    Text="{markup:I18n Key=Text_UpdateConfig}"
                    Click="ContextMenu_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE753;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="Edit"
                    Text="{markup:I18n Key=Text_Edit}"
                    Click="ContextMenu_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem 
                    x:Name="Preview"                         
                    Text="{markup:I18n Key=Text_Preview}"
                    Click="ContextMenu_Click" >
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8A1;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem 
                    x:Name="Apply" 
                    Text="{markup:I18n Key=Text_Apply}"
                    Click="ContextMenu_Click" >
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8FB;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem 
                    x:Name="LockBackground" 
                    Text="{markup:I18n Key=Text_ApplyToLockBG}"
                    Click="ContextMenu_Click" >
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xEE3F;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="ShowOnDisk"
                    Text="{markup:I18n Key=Text_ShowOnDisk}"
                    Click="ContextMenu_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xED25;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="DeleteFromDisk"
                    Text="{markup:I18n Key=Text_DeleteFromDisk}"
                    Click="ContextMenu_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon 
                            Glyph="&#xE74D;" 
                            Foreground="Goldenrod"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </GridView.ContextFlyout>
    </GridView>
</arc:ArcPage>
