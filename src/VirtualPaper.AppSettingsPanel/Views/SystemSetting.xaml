<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.AppSettingsPanel.Views.SystemSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.AppSettingsPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"    
    NavigationCacheMode="Enabled">

    <ScrollView>
        <StackPanel Margin="15 0 15 15" Orientation="Vertical">

            <StackPanel x:Name="Developer" Orientation="Vertical">

                <TextBlock x:Name="DeveloperHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_System_Text_Developer}"   
                    FontWeight="Bold"/>

                <Grid x:Name="Debug"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xEC7A;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_System_Developer_Debug}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_System_Developer_DebugExplain}"/>
                    </Grid>

                    <Button
                        Grid.Column="2"
                        Width="200"
                        Content="{markup:I18n Key=Settings_System_Text_Debug}"
                        Command="{x:Bind _viewModel.DebugCommand}"/>
                </Grid>

                <Grid x:Name="Log"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE9F9;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_System_Developer_Log}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_System_Developer_LogExplain}"/>
                    </Grid>

                    <Button
                        Grid.Column="2"
                        Width="200"
                        Content="{markup:I18n Key=Settings_System_Log}"
                        Command="{x:Bind _viewModel.LogCommand}"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
