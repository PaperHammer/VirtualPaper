<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.UIComponent.Feedback.Loading"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.UIComponent.Feedback"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:cvs="using:VirtualPaper.UIComponent.Converters"   
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    IsHitTestVisible="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <cvs:VisibilityByValueConverter x:Key="VisibilityByValueConverter"/>
    </UserControl.Resources>

    <Grid>
        <Rectangle x:Name="OverlayMask"
            Fill="{ThemeResource SolidBackgroundFillColorBase}"
            Opacity="0.7"/>
        
        <StackPanel
            Padding="0 0 18 0"
            Orientation="Vertical"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
            <Grid Margin="20" HorizontalAlignment="Center">
                <ProgressRing x:Name="progressRing"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    IsActive="True"
                    Height="50"
                    Width="50"
                    Background="Transparent"/>
            </Grid>

            <Grid
                Margin="20"
                HorizontalAlignment="Center"            
                Visibility="{x:Bind ProgressbarEnable, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <ProgressBar 
                    Margin="0 0 20 0"
                    Width="340"
                    Value="{x:Bind CurValue, Mode=OneWay}"
                    Maximum="{x:Bind TotalValue, Mode=OneWay}"/>

                <TextBlock
                    Grid.Column="1"
                    FontWeight="Bold"
                    Text="{x:Bind ValueString, Mode=OneWay}"/>
            </Grid>

            <Button x:Name="BtnCancel"                   
                Margin="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="100" 
                Height="40"
                Visibility="{x:Bind CancelEnable, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}}"
                Content="{markup:I18n Key=Text_Cancel}"
                Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
