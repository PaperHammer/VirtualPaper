<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.AppSettingsPanel.Views.PerformanceSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.AppSettingsPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <ScrollView>
        <StackPanel Margin="15 0 15 15" Orientation="Vertical">
            <StackPanel x:Name="Play" Orientation="Vertical">
                <TextBlock x:Name="PlayHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_Perforemance_Text_Play}"
                    FontWeight="Bold"/>

                <Grid
                    x:Name="OthersFullScreen"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE7B5;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_Play_OthersFullScreen}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_Play_OthersFullScreenExplain}"/>
                    </Grid>

                    <ComboBox x:Name="OthersFullScreenPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.PlayStatus}"
                        SelectedIndex="{x:Bind _viewModel.SelectedFullScreenPlayStatuIndex, Mode=TwoWay}"
                        Width="200" />
                </Grid>

                <Grid x:Name="OthersFocus"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xED35;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_Play_OthersFocus}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_Play_OthersFocusExplain}"/>
                    </Grid>

                    <ComboBox x:Name="OthersFocusPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.PlayStatus}"
                        SelectedIndex="{x:Bind _viewModel.SelectedFocusPlayStatuIndex, Mode=TwoWay}"
                        Width="200" />
                </Grid>

                <Grid x:Name="Audio"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xED1F;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_Play_Audio}"/>
                    </Grid>

                    <ToggleButton
                        Grid.Column="2"
                        Width="200"
                        Content="{x:Bind _viewModel.AudioStatu, Mode=OneWay}" 
                        IsChecked="{x:Bind _viewModel.IsAudioOnlyOnDesktop, Mode=TwoWay}"/>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="Laptop"
                Margin="0 20 0 0"
                Orientation="Vertical">

                <TextBlock x:Name="LaptopHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_Perforemance_Text_Laptop}"
                    FontWeight="Bold"/>

                <Grid x:Name="BatteryPoweredn"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xEBA7;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_Laptop_BatteryPoweredn}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_Laptop_BatteryPowerednExplain}"/>
                    </Grid>

                    <ComboBox x:Name="BatteryPowerednPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.PlayStatus}"
                        SelectedIndex="{x:Bind _viewModel.SelectedBatteryPowerednPlayStatuIndex, Mode=TwoWay}"
                        Width="200" />
                </Grid>

                <Grid x:Name="PowerSaving"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xEBB9;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_Laptop_PowerSaving}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_Laptop_PowerSavingExplain}"/>
                    </Grid>

                    <ComboBox x:Name="PowerSavingPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.PlayStatus}"
                        SelectedIndex="{x:Bind _viewModel.SelectedPowerSavingPlayStatuIndex, Mode=TwoWay}"
                        Width="200" />
                </Grid>
            </StackPanel>

            <StackPanel x:Name="System"
                Margin="0 20 0 0"
                Orientation="Vertical">

                <TextBlock x:Name="SystemHeader"
                    Margin="0 10"
                    Text="{markup:I18n Key=Settings_Perforemance_Text_System}"
                    FontWeight="Bold"/>

                <Grid x:Name="RemoteDesktop"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE703;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_System_RemoteDesktop}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_System_RemoteDesktopExplain}"/>
                    </Grid>

                    <ComboBox x:Name="RemoteDesktopPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.PlayStatus}"
                        SelectedIndex="{x:Bind _viewModel.SelectedRemoteDesktopPlayStatuIndex, Mode=TwoWay}"
                        Width="200" />
                </Grid>

                <Grid x:Name="StatuMechanism"
                    Height="90"
                    Margin="0 5"
                    Padding="20 0"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Margin="0 0 20 0" Glyph="&#xE7F4;"/>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:I18n Key=Settings_Perforemance_System_StatuMechanism}"/>
                        <TextBlock 
                            Grid.Row="1" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_System_StatuMechanismExplain_ForPer}"/>
                        <TextBlock 
                            Grid.Row="2" 
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{markup:I18n Key=Settings_Perforemance_System_StatuMechanismExplain_ForAll}"/>
                    </Grid>

                    <ComboBox x:Name="StatuMechanismPlayStatusCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind _viewModel.StatuMechanisms}"
                        SelectedIndex="{x:Bind _viewModel.SelectedStatuMechanismPlayStatuIndex, Mode=TwoWay}"
                        Width="200"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
