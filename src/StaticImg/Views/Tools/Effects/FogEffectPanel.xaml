<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.FogEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 缩放 -->
        <TextBlock Text="缩放" FontSize="14"/>
        <ComboBox x:Name="ScaleCombo"
            SelectedIndex="2"
            SelectionChanged="ScaleCombo_SelectionChanged">
            <x:String>×1</x:String>
            <x:String>×2</x:String>
            <x:String>×4</x:String>
            <x:String>×8</x:String>
        </ComboBox>

        <!-- 浓度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="浓度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="AmountValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="AmountSlider"
            Minimum="0" Maximum="100" Value="50"
            TickFrequency="12.5" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="AmountSlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
