<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvs="using:VirtualPaper.UIComponent.Converters">
    
    <cvs:BoolByValueConverter x:Key="BoolByValueConverter"/>
    <cvs:IsStringConverter x:Key="IsStringConverter"/>
    <cvs:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
    <cvs:VisibilityByValueConverter x:Key="VisibilityByValueConverter"/>
    <cvs:LocalizeConv x:Key="LocalizeConv"/>
    <cvs:ByteArrayToBrushConverter x:Key="ByteArrayToBrushConverter"/>
    <cvs:ResourceKeyToImageConverter x:Key="ResourceKeyToImageConverter"/>

    <BitmapImage x:Key="AppIcon" UriSource="ms-appx:///Assets/icon-vp-512.png"/>
    <BitmapImage x:Key="NaviIcon_ThemeLight" UriSource="ms-appx:///Assets/ui_components/Light/theme_light.png"/>
    <BitmapImage x:Key="NaviIcon_ThemeDark" UriSource="ms-appx:///Assets/ui_components/Dark/theme_dark.png"/>
    <BitmapImage x:Key="UIC_Create_Common" UriSource="ms-appx:///Assets/ui_components/icons8-image-96.png"/>
    <BitmapImage x:Key="UIC_Create_3D" UriSource="ms-appx:///Assets/ui_components/icons8-picture-94.png"/>
    <BitmapImage x:Key="DraftPanel_Create_StaticImge_Desc" UriSource="ms-appx:///Assets/ui_components/project-create-static-image-desc.png"/>
    <BitmapImage x:Key="DraftPanel_Create_StaticImge_LayerThu" UriSource="ms-appx:///Assets/staticImg/layer_thu_grid.png"/>
    
    <BitmapImage x:Key="PresetStyles_Anime" UriSource="ms-appx:///Assets/intelligent/preset_styles/anime.jpg"/>
    <BitmapImage x:Key="PresetStyles_Cartoon" UriSource="ms-appx:///Assets/intelligent/preset_styles/cartoon.jpg"/>
    <BitmapImage x:Key="PresetStyles_Gongbi" UriSource="ms-appx:///Assets/intelligent/preset_styles/gongbi.jpg"/>
    <BitmapImage x:Key="PresetStyles_Pencil" UriSource="ms-appx:///Assets/intelligent/preset_styles/pencil.jpg"/>
    <BitmapImage x:Key="PresetStyles_Watercolor" UriSource="ms-appx:///Assets/intelligent/preset_styles/watercolor.jpg"/>
    <BitmapImage x:Key="PresetStyles_InkWash" UriSource="ms-appx:///Assets/intelligent/preset_styles/ink_wash.jpg"/>
    <BitmapImage x:Key="PresetStyles_OilPainting" UriSource="ms-appx:///Assets/intelligent/preset_styles/oil_painting.jpg"/>
    <BitmapImage x:Key="PresetStyles_ColoredPencil" UriSource="ms-appx:///Assets/intelligent/preset_styles/colored_pencil.jpg"/>
    <BitmapImage x:Key="PresetStyles_OutlineDrawing" UriSource="ms-appx:///Assets/intelligent/preset_styles/outline_drawing.jpg"/>
    <BitmapImage x:Key="PresetStyles_Ukiyoe" UriSource="ms-appx:///Assets/intelligent/preset_styles/ukiyo-e.jpg"/>

    <Style x:Key="RightExpanderStyle" TargetType="Expander">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="IsExpanded" Value="True"/>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Visibility" Value="Collapsed"/>
    </Style>
    
    <Style TargetType="Control" BasedOn="{StaticResource DefaultControlStyle}">
        <Setter Property="KeyboardAcceleratorPlacementMode" Value="Hidden"/>
        <Setter Property="IsTabStop" Value="True"/>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
        <Setter Property="ContextFlyout" Value="{x:Null}"/>
        <Setter Property="IsSpellCheckEnabled" Value="False"/>
    </Style>

    <Style x:Key="MorePronouncedButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush }"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <ContentPresenter x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
