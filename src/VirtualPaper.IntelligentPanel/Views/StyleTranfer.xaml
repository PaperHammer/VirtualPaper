<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.IntelligentPanel.Views.StyleTranfer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.IntelligentPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:local_self_comp="using:VirtualPaper.IntelligentPanel.Views.StyleTransferComp"
    xmlns:local_comp="using:VirtualPaper.IntelligentPanel.Views.Comp"
    mc:Ignorable="d">

    <Grid>
        <local_self_comp:StyleTransferIntroduction
            Visibility="{x:Bind _viewModel.HasTasks, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=!}"/>

        <local_comp:TasksView
            Visibility="{x:Bind _viewModel.HasTasks, Mode=OneWay}"/>
    </Grid>
</arc:ArcPage>
