<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VirtualPaper.IntelligentPanel.Views.Comp.TasksView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.IntelligentPanel.Views.Comp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lcl_models="using:VirtualPaper.IntelligentPanel.Models"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    mc:Ignorable="d">

    <Grid Margin="12">
        <ListView
            x:Name="TaskListView"
            ItemsSource="{x:Bind Tasks}"
            SelectionMode="None"
            IsItemClickEnabled="False"
            Padding="0 0 16 0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="lcl_models:StyleTransferTaskItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Expander
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Padding="20 0"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1">

                            <Expander.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Padding="0 18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center" Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock 
                                                    Text="{markup:I18n Key=Intelligent_Task_Scr_Img}" 
                                                    FontSize="14" 
                                                    Width="100"/>
                                                <TextBlock
                                                    Text="{x:Bind SourceFilePath}"
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxLines="1"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{markup:I18n Key=Intelligent_Task_Style}"
                                                    FontSize="14"
                                                    Width="100"/>
                                                <TextBlock
                                                    Text="{x:Bind StyleName}"
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxLines="1"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="20,0,16,0"
                                            Spacing="2">
                                            <StackPanel Spacing="2" Orientation="Horizontal">
                                                <TextBlock
                                                    Text="{x:Bind StatusText, Mode=OneWay}"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{x:Bind StatusColor, Mode=OneWay, Converter={StaticResource ByteArrayToBrushConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">

                                            <input:ArcButton Command="{x:Bind PreviewCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{markup:I18n Key=Text_Preview}" FontSize="14"/>
                                                </StackPanel>
                                            </input:ArcButton>

                                            <input:ArcButton Command="{x:Bind ImportCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{markup:I18n Key=Text_ImportLib}" FontSize="14"/>
                                                </StackPanel>
                                            </input:ArcButton>

                                            <input:ArcButton Command="{x:Bind SaveCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{markup:I18n Key=Text_Save}" FontSize="14"/>
                                                </StackPanel>
                                            </input:ArcButton>

                                            <input:ArcButton
                                                Command="{x:Bind RemoveCommand}"
                                                BorderBrush="#FFE0B0B0"
                                                Background="#20FF4D6A"
                                                Foreground="#FFD13438">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{markup:I18n Key=Text_Delete}" FontSize="14" Foreground="#FFD13438"/>
                                                </StackPanel>
                                            </input:ArcButton>
                                        </StackPanel>
                                    </Grid>

                                    <ProgressBar
                                        Grid.Row="1"
                                        IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}"
                                        ShowError="{x:Bind IsShowError, Mode=OneWay}"
                                        Value="{x:Bind Progress, Mode=OneWay}"
                                        Foreground="{x:Bind StatusColor, Mode=OneWay, Converter={StaticResource ByteArrayToBrushConverter}}"
                                        Height="3"
                                        Width="310"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"/>
                                </Grid>
                            </Expander.Header>

                            <Expander.Content>
                                <StackPanel
                                    Padding="16,12"
                                    MinHeight="120"
                                    Spacing="10">
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel HorizontalAlignment="Center" Spacing="6">

                                            <TextBlock 
                                                Text="{markup:I18n Key=Intelligent_Task_Scr_Img}"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"/>

                                            <Grid>
                                                <Rectangle
                                                    RadiusX="14"
                                                    RadiusY="14"
                                                    Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                                                    StrokeThickness="1.5"
                                                    StrokeDashArray="4 3"
                                                    Fill="Transparent"/>

                                                <Border x:Name="sourceImageBorder"
                                                    Width="400"
                                                    Height="250"
                                                    Margin="10"
                                                    CornerRadius="10"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                    <Image x:Name="sourceImage"
                                                        Stretch="UniformToFill"
                                                        Source="{x:Bind SourceFilePath, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}" />
                                                </Border>
                                            </Grid>

                                            <StackPanel 
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="16">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE809;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock 
                                                        Text="{x:Bind SourceResolution}" 
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEB05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock 
                                                        Text="{x:Bind SourceFileSize, Mode=OneWay}" 
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock 
                                                        Text="{x:Bind SourceFileExt, Mode=OneWay}" 
                                                        FontSize="14" 
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel 
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6">

                                            <Grid HorizontalAlignment="Stretch">
                                                <TextBlock 
                                                    Text="{markup:I18n Key=Intelligent_Style_Img}"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid>
                                                <Rectangle
                                                    RadiusX="14"
                                                    RadiusY="14"
                                                    Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                                                    StrokeThickness="1.5"
                                                    StrokeDashArray="4 3"
                                                    Fill="Transparent"/>

                                                <Border x:Name="styleImageBorder"
                                                    Width="300"
                                                    Height="250"
                                                    Margin="10"
                                                    CornerRadius="10"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                    <Image x:Name="styleImage"
                                                        Stretch="UniformToFill"
                                                        Source="{x:Bind StyleFilePath, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}" />
                                                </Border>
                                            </Grid>

                                            <StackPanel HorizontalAlignment="Center">
                                                <StackPanel 
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="16">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE790;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock 
                                                            Text="{x:Bind StyleName, TargetNullValue={markup:I18n Key=Intelligent_Task_Style_Img_Import}, Mode=OneWay}" 
                                                            FontSize="14"
                                                            MaxWidth="120"
                                                            TextTrimming="CharacterEllipsis"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xEB05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock 
                                                            Text="{x:Bind StyleFileSize, Mode=OneWay}" 
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock 
                                                            Text="{x:Bind StyleFileExt, Mode=OneWay}" 
                                                            FontSize="14" 
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel HorizontalAlignment="Center" Spacing="6">

                                        <TextBlock 
                                            Text="{markup:I18n Key=Text_Synthesis_Result}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"/>

                                        <Grid>
                                            <Rectangle
                                                RadiusX="14"
                                                RadiusY="14"
                                                Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                                                StrokeThickness="1.5"
                                                StrokeDashArray="4 3"
                                                Fill="Transparent"/>

                                            <Border x:Name="resultImageBorder"
                                                Width="400"
                                                Height="250"
                                                Margin="10"
                                                CornerRadius="10"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                                <Image x:Name="resultImage"
                                                    Stretch="UniformToFill"
                                                    Source="{x:Bind ResultFilePath, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}" />
                                            </Border>
                                        </Grid>

                                        <StackPanel 
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE809;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock 
                                                    Text="{x:Bind ResultResolution, Mode=OneWay}" 
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xEB05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock 
                                                    Text="{x:Bind ResultFileSize, Mode=OneWay}" 
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock 
                                                    Text="{x:Bind ResultFileExt, Mode=OneWay}" 
                                                    FontSize="14" 
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander.Content>
                        </Expander>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>