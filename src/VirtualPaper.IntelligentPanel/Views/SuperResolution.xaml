<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VirtualPaper.IntelligentPanel.Views.SuperResolution"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.IntelligentPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local_self_comp="using:VirtualPaper.IntelligentPanel.Views.SuperResolutionComp"
    xmlns:local_comp="using:VirtualPaper.IntelligentPanel.Views.Comp"
    mc:Ignorable="d">

    <Grid>
        <local_self_comp:Introduction
            Visibility="{x:Bind _viewModel.HasTasks, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=!}"/>

        <local_comp:TasksView
            Visibility="{x:Bind _viewModel.HasTasks, Mode=OneWay}"/>
    </Grid>
</Page>
