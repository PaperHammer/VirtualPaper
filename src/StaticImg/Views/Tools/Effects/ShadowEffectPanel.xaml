<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.ShadowEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 模糊 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="模糊" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="BlurValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="BlurSlider"
            Minimum="0" Maximum="100" Value="0"
            TickFrequency="12.5" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="BlurSlider_ValueChanged"/>

        <!-- 偏移X -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="偏移X" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="OffsetXValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="OffsetXSlider"
            Minimum="-200" Maximum="200" Value="0"
            TickFrequency="50" TickPlacement="BottomRight"
            SmallChange="4" StepFrequency="4"
            ValueChanged="OffsetXSlider_ValueChanged"/>

        <!-- 偏移Y -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="偏移Y" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="OffsetYValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="OffsetYSlider"
            Minimum="-200" Maximum="200" Value="0"
            TickFrequency="50" TickPlacement="BottomRight"
            SmallChange="4" StepFrequency="4"
            ValueChanged="OffsetYSlider_ValueChanged"/>

        <!-- 透明度 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="透明度" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="OpacityValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="OpacitySlider"
            Minimum="0" Maximum="100" Value="0"
            TickFrequency="12.5" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="OpacitySlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
