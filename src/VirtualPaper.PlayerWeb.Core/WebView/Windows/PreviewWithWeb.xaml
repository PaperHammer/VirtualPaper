<?xml version="1.0" encoding="utf-8"?>
<arc:ArcWindow
    x:Class="VirtualPaper.PlayerWeb.Core.WebView.Windows.PreviewWithWeb"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.PlayerWeb.Core.WebView.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:navi="using:VirtualPaper.UIComponent.Navigation"
    mc:Ignorable="d"
    Width="1400" Height="850"
    Title="Virtual Paper Preview">

    <arc:ArcWindowHost x:Name="MainHost" Title="Virtual Paper Preview">
        <navi:ArcNavigationContentView x:Name="NaviContent" 
            Loaded="NaviContent_Loaded"
            InfobarMessages="{x:Bind InfobarMessages}"/>
    </arc:ArcWindowHost>
</arc:ArcWindow>
