<?xml version="1.0" encoding="utf-8"?>
<local:EffectPanelBase
    x:Class="Workloads.Creation.StaticImg.Views.Tools.Effects.BrightnessEffectPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workloads.Creation.StaticImg.Views.Tools.Effects"
    xmlns:input="using:VirtualPaper.UIComponent.Input"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- 黑场 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="黑场" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="BlackValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="BlackSlider"
            Minimum="0" Maximum="255" Value="0"
            TickFrequency="32" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="BlackSlider_ValueChanged"/>

        <!-- 白场 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="白场" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="WhiteValueText" Grid.Column="1" FontSize="13" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
        <input:ArcSlider x:Name="WhiteSlider"
            Minimum="0" Maximum="255" Value="255"
            TickFrequency="32" TickPlacement="BottomRight"
            SmallChange="1" StepFrequency="1"
            ValueChanged="WhiteSlider_ValueChanged"/>
    </StackPanel>
</local:EffectPanelBase>
