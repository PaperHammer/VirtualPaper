<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.IntelligentPanel.Views.SuperResolutionComp.SuperResolutionAddTask"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.IntelligentPanel.Views.SuperResolutionComp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lcl_models="using:VirtualPaper.IntelligentPanel.Models"
    xmlns:uicomp_utils="using:VirtualPaper.UIComponent.Utils"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"
    Unloaded="Page_Unloaded">

    <Grid x:Name="addTaskGrid"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel HorizontalAlignment="Center" Spacing="6">

            <TextBlock 
                Text="{markup:I18n Key=Intelligent_Task_Scr_Img}"
                FontSize="16"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>

            <Grid>
                <Rectangle
                    RadiusX="14"
                    RadiusY="14"
                    Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                    StrokeThickness="1.5"
                    StrokeDashArray="4 3"
                    Fill="Transparent"/>

                <Border x:Name="sourceImageBorder"
                    Width="400"
                    Height="250"
                    Margin="10"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    AllowDrop="True"
                    uicomp_utils:CursorUtil.CursorShape="Hand"
                    Tapped="SourceImageBorder_Tapped">
                    <Grid>
                        <StackPanel 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="6"
                            Visibility="{x:Bind _viewModel.SourceFilePath, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=!HasValue}">
                            <FontIcon 
                                Glyph="&#xE8B9;"
                                FontSize="28"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock 
                                Text="{markup:I18n Key=Intelligent_Task_Scr_Img_Import}"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontSize="14"/>
                        </StackPanel>

                        <Image x:Name="sourceImage"
                            Stretch="UniformToFill"
                            Source="{x:Bind _viewModel.SourceFilePath, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}" />
                    </Grid>
                </Border>
            </Grid>

            <StackPanel 
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="16"
                Visibility="{x:Bind _viewModel.SourceFilePath, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=HasValue}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE809;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="{x:Bind _viewModel.SourceFileResolution, Mode=OneWay}" 
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEB05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="{x:Bind _viewModel.SourceFileSize, Mode=OneWay}" 
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="{x:Bind _viewModel.SourceFileExt, Mode=OneWay}" 
                        FontSize="14" 
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Grid 
            Grid.Column="1"
            VerticalAlignment="Center"
            Margin="20,-40,20,0">
            <Border 
                Width="44"
                Height="44"
                CornerRadius="22"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <FontIcon 
                    Glyph="&#xE72A;"
                    FontSize="16"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <StackPanel 
            Grid.Column="2"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Spacing="12">

            <TextBlock 
                Text="{markup:I18n Key=Intelligent_Enhance_Mode}"
                FontSize="16"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>

            <Border
                Width="320"
                Padding="20"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="16">

                    <RadioButton x:Name="qualityRestoreRadio"
                        GroupName="EnhanceMode"
                        IsChecked="{x:Bind _viewModel.IsQualityRestoreMode, Mode=TwoWay}"
                        Checked="EnhanceMode_Changed">
                        <StackPanel Spacing="2">
                            <TextBlock 
                                Text="{markup:I18n Key=Intelligent_Enhance_QualityRestore}"
                                FontSize="14"
                                FontWeight="SemiBold"/>
                            <TextBlock 
                                Text="{markup:I18n Key=Intelligent_Enhance_QualityRestore_Desc}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>

                    <Border 
                        Height="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        HorizontalAlignment="Stretch"/>

                    <RadioButton x:Name="superResolutionRadio"
                        GroupName="EnhanceMode"
                        IsChecked="{x:Bind _viewModel.IsSuperResolutionMode, Mode=TwoWay}"
                        Checked="EnhanceMode_Changed">
                        <StackPanel Spacing="2">
                            <TextBlock 
                                Text="{markup:I18n Key=Intelligent_Enhance_SuperResolution}"
                                FontSize="14"
                                FontWeight="SemiBold"/>
                            <TextBlock 
                                Text="{markup:I18n Key=Intelligent_Enhance_SuperResolution_Desc}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>

                    <StackPanel 
                        Spacing="10"
                        Margin="28,0,0,0"
                        Visibility="{x:Bind _viewModel.IsSuperResolutionMode, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}}">

                        <TextBlock 
                            Text="{markup:I18n Key=Intelligent_Enhance_Magnification}"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton x:Name="mag2xRadio"
                                GroupName="Magnification"
                                Content="2×"
                                MinWidth="60"
                                IsChecked="{x:Bind _viewModel.IsMag2x, Mode=TwoWay}"
                                Checked="Magnification_Changed"
                                Style="{ThemeResource DefaultToggleButtonStyle}"/>
                            <RadioButton x:Name="mag4xRadio"
                                GroupName="Magnification"
                                Content="4×"
                                MinWidth="60"
                                IsChecked="{x:Bind _viewModel.IsMag4x, Mode=TwoWay}"
                                Checked="Magnification_Changed"
                                Style="{ThemeResource DefaultToggleButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                Visibility="{x:Bind _viewModel.OutputResolutionText, Mode=OneWay, Converter={StaticResource VisibilityByValueConverter}, ConverterParameter=HasValue}">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <FontIcon 
                        Glyph="&#xE809;" 
                        FontSize="14" 
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock 
                        Text="{markup:I18n Key=Intelligent_Enhance_Output}"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="{x:Bind _viewModel.OutputResolutionText, Mode=OneWay}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <StackPanel 
                Padding="4,4" 
                Orientation="Horizontal" 
                Spacing="8" 
                HorizontalAlignment="Center">
                <FontIcon 
                    Glyph="&#xE946;"
                    FontSize="13"
                    VerticalAlignment="Top"
                    Margin="0,2,0,0"/>
                <TextBlock 
                    Text="{markup:I18n Key=Intelligent_Enhance_Tip}"
                    FontSize="12"
                    TextWrapping="Wrap"
                    MaxWidth="280"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</arc:ArcPage>