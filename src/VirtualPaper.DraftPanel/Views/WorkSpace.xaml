<?xml version="1.0" encoding="utf-8"?>
<arc:ArcPage
    x:Class="VirtualPaper.DraftPanel.Views.WorkSpace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VirtualPaper.DraftPanel.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:cmd="using:VirtualPaper.UIComponent.Command"
    xmlns:navi="using:VirtualPaper.UIComponent.Navigation"
    xmlns:arc="using:VirtualPaper.UIComponent.Templates"
    xmlns:markup="using:VirtualPaper.UIComponent.ArcMarkupExtension"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <cmd:KeepToLeft x:Key="LeftMenuItems">
            <MenuBarItem Title="{markup:I18n Key=Project_StaticImg_MenuBar_Text_File}"
                KeyboardAcceleratorPlacementMode="Hidden">
                <MenuBarItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Menu" Key="F"/>
                </MenuBarItem.KeyboardAccelerators>

                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_CreateNew}">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="N"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <!--<MenuFlyoutItem Text="添加">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="D"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>-->
                <MenuFlyoutItem Text="{markup:I18n Key=Project_Open}">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="{markup:I18n Key=Text_Save}" Click="MFI_Save_Clicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_SaveAll}" Click="MFI_SaveAll_Clicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="S"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Exit}" Click="MFI_Exit_Clicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="F4"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>

            <MenuBarItem Title="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Edit}"
                KeyboardAcceleratorPlacementMode="Hidden">
                <MenuBarItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Menu" Key="E"/>
                </MenuBarItem.KeyboardAccelerators>

                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Undo}" Click="MFI_Undo_Clicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Redo}" Click="MFI_Redo_Clicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control, Shift" Key="Z"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>

                <!--<MenuFlyoutSeparator />-->

                <!--<MenuFlyoutItem Text="剪切">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="X"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="复制">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="C"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="粘贴">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="V"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>-->
            </MenuBarItem>
        </cmd:KeepToLeft>

        <cmd:KeepToRight x:Key="RightMenuItems">
            <MenuBarItem Title="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Help}"
              KeyboardAcceleratorPlacementMode="Hidden">
                <MenuBarItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Menu" Key="H"/>
                </MenuBarItem.KeyboardAccelerators>

                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Repo}">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="None" Key="R"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>

                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_Manual}">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="None" Key="M"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>

                <MenuFlyoutItem Text="{markup:I18n Key=Project_StaticImg_MenuBar_Text_About}">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="None" Key="A"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>
        </cmd:KeepToRight>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <ContentControl x:Name="menuContent">
            <cmd:ObservableMenuBar
                KeepToLeft="{StaticResource LeftMenuItems}"
                KeepToRight="{StaticResource RightMenuItems}"
                MiddleItems="{x:Bind _viewModel._middleMenuItems}"/>
        </ContentControl>

        <Grid x:Name="contentGrid" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TabView x:Name="TabViewControl"
                Loaded="TabViewControl_Loaded"
                TabWidthMode="SizeToContent"
                SelectedIndex="{x:Bind _viewModel.SelectedTabIndex, Mode=TwoWay}"
                TabItemsSource="{x:Bind _viewModel.TabViewItems}"
                CloseButtonOverlayMode="OnPointerOver"
                TabItemsChanged="TabViewControl_TabItemsChanged"   
                SelectionChanged="TabViewControl_SelectionChanged"
                AddTabButtonClick="TabViewControl_AddTabButtonClick"
                TabCloseRequested="TabViewControl_TabCloseRequested" />

            <Grid x:Name="workspaceContentPool" Grid.Row="1" />
        </Grid>

        <Grid x:Name="maskGrid" 
            Grid.RowSpan="2" 
            Background="#80000000" 
            Visibility="Collapsed"
            Tapped="MaskGrid_Tapped">

            <Frame x:Name="overlayFrame" 
                Width="970" 
                Height="680"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                Tapped="OverlayFrame_Tapped"/>
        </Grid>
    </Grid>
</arc:ArcPage>
